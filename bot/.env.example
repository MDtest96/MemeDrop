# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Discord application/client ID
CLIENT_ID=your_application_id_here

# Local dev port (Railway provides PORT automatically and ignores this)
WS_PORT=8765

# Optional: comma-separated guild IDs for instant slash-command registration during dev
DEV_GUILD_IDS=

# Secret used to sign zero-touch re-link tokens (HMAC). Set this to a long
# random string and keep it stable across redeploys — if it changes, every
# overlay must run /link once again. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LINK_SECRET=
